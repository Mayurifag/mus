---
# Instruction for AI - if you change this file, you have also change ./docker-compose.override.yml.example file with same changes.

x-backend-environment: &x-backend-environment
  APP_ENV: development
  FRONTEND_ORIGIN: http://localhost:5173
  LOG_LEVEL: INFO

x-backend-volumes: &x-backend-volumes
  - ../backend-rs:/app
  - backend_cargo:/cargo
  - backend_target:/app/target
  - /path/to/your/music:/app_data/music
  - app_data_database:/app_data/database
  - app_data_covers:/app_data/covers
  # Optional: Mount cookies.txt for yt-dlp authenticated downloads
  # - ./cookies.txt:/app_data/cookies.txt:ro

services:
  backend:
    ports:
      - "8001:8001"
    volumes: *x-backend-volumes
    environment:
      <<: *x-backend-environment
    restart: unless-stopped

  frontend:
    ports:
      - "5173:5173"
    volumes:
      - ../frontend:/app
      - app_node_modules:/app/node_modules
    environment:
      VITE_INTERNAL_API_HOST: http://backend:8001
      VITE_PUBLIC_API_HOST: http://localhost:8001
      VITE_EFFECTS_DEBUG: true
    restart: unless-stopped

volumes:
  app_node_modules:
  backend_cargo:
  backend_target:
  app_data_database:
  app_data_covers:
