---
# Instruction for AI - if you change this file, you have also change ./docker-compose.override.yml.example file with same changes.

x-backend-environment: &x-backend-environment
  APP_ENV: development
  FRONTEND_ORIGIN: http://localhost:5173
  SECRET_KEY: dev_secret_key_please_change_in_production
  REDIS_URL: redis://redis:6379
  BACKEND_URL: http://backend:8001
  WATCHFILES_FORCE_POLLING: true
  WATCHFILES_POLL_DELAY_MS: 2000
  LOG_LEVEL: INFO
  OLLAMA_URL: http://ollama:11434

x-backend-volumes: &x-backend-volumes
  - ../backend:/app
  - backend_venv:/opt/venv
  - /path/to/your/music:/app_data/music
  - app_data_database:/app_data/database
  - app_data_covers:/app_data/covers
  # Optional: Mount cookies.txt for yt-dlp authenticated downloads
  # - ./cookies.txt:/app_data/cookies.txt:ro

services:
  backend:
    ports:
      - "8001:8001"
    volumes: *x-backend-volumes
    environment:
      <<: *x-backend-environment
    restart: unless-stopped

  frontend:
    ports:
      - "5173:5173"
    volumes:
      - ../frontend:/app
      - app_node_modules:/app/node_modules
    environment:
      SECRET_KEY: dev_secret_key_please_change_in_production
      VITE_INTERNAL_API_HOST: http://backend:8001
      VITE_PUBLIC_API_HOST: http://localhost:8001
      VITE_EFFECTS_DEBUG: true
    restart: unless-stopped

  redis:
    ports:
      - "6379:6379"

  streaq-worker:
    volumes: *x-backend-volumes
    environment:
      <<: *x-backend-environment

  ollama:
    ports:
      - "11434:11434"
    volumes:
      - ollama_models:/root/.ollama
    environment:
      OLLAMA_KEEP_ALIVE: -1
    entrypoint: ["/bin/bash", "-c"]
    command:
      - |
        ollama serve &
        until ollama list >/dev/null 2>&1; do sleep 1; done
        if ! ollama list | grep -q 'qwen3.5:2b'; then
          echo "Pulling qwen3.5:2b..."
          ollama pull qwen3.5:2b >/dev/null 2>&1 &
          PULL_PID=$$!
          while kill -0 $$PULL_PID 2>/dev/null; do
            sleep 30
            echo "Still pulling qwen3.5:2b..."
          done
          wait $$PULL_PID && echo "qwen3.5:2b ready"
        fi
        echo "Preloading qwen3.5:2b into memory..."
        ollama run qwen3.5:2b "" >/dev/null 2>&1 || true
        echo "qwen3.5:2b loaded and ready"
        wait

volumes:
  app_node_modules:
  backend_venv:
  app_data_database:
  app_data_covers:
  ollama_models:
