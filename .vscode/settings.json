{
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "always"
  },
  "[json]": {
    "editor.wordWrap": "on"
  },
  "[jsonc]": {
    "editor.wordWrap": "on"
  },
  "[markdown]": {
    "editor.wordWrap": "on"
  },
  "workbench.editorAssociations": {
    "*.mdc": "default"
  },
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/*.so": true,
    "**/*.dylib": true,
    "**/*.dll": true,
    "**/*.exe": true,
    "**/dist": true,
    "**/build": true,
    "**/node_modules": true,
    "**/.svelte-kit": true,
    "**/.vite": true,
    "**/backend/app_data/**": true,
    "**/e2e/test-results/**": true,
    "**/e2e/playwright-report/**": true
  },
  "svelte.enable-ts-plugin": true
}
