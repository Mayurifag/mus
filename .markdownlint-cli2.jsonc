{
  "config": {
    "MD013": {
      "line_length": 222
    }
  },
  "fix": true,
  "globs": [
    "**/*.{md,markdown}",
    "!**/node_modules/**",
    "!**/.venv/**",
    "!docker/.venv/**",
    "!e2e/playwright-report/**",
    "!e2e/test-results/**",
    "!AGENT_TASKS/**"
  ],
  "noBanner": true
}
